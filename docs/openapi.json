","description":"Opponent's display name"},"opponentNumberOfAliveCells":{"type":"integer","format":"int32","description":"Number of the opponent's board cells still occupied by unsunk ships"},"opponentNumberOfAliveShips":{"type":"integer","format":"int32","description":"Number of the opponent's ships not yet fully sunk"},"opponentField":{"type":"array","description":"Opponent's board as visible to the requesting player, as a 2D array of cells","items":{"type":"array","items":{"$ref":"#/components/schemas/CellDto"}}},"hasWinner":{"type":"boolean","description":"Whether the game has a winner"},"winnerPlayerName":{"type":"string","description":"Winning player's display name, if any"},"isPlayerActive":{"type":"boolean","description":"Whether it is currently this player's turn"},"isPlayerWinner":{"type":"boolean","description":"Whether this player has won the game"},"isOpponentReady":{"type":"boolean","description":"Whether the opponent has readied up"}}},"Ship":{"type":"object","properties":{"shipId":{"type":"string"},"shipType":{"type":"string","enum":["PATROL_BOAT","SUBMARINE","DESTROYER","BATTLESHIP","CARRIER"]},"shipDirection":{"type":"string","enum":["HORIZONTAL","VERTICAL"]},"shipSize":{"type":"integer","format":"int32"}}},"ResponsePreparationState":{"type":"object","properties":{"ships":{"type":"array","description":"Ships still available to place","items":{"$ref":"#/components/schemas/ShipDto"}},"field":{"type":"array","description":"Player's current board, as a 2D array of cells","items":{"type":"array","items":{"$ref":"#/components/schemas/CellDto"}}}}},"ShipDto":{"type":"object","properties":{"shipId":{"type":"string","description":"Ship type identifier from the edition's ship catalog","example":"patrol_boat_1"},"shipSize":{"type":"integer","format":"int32","description":"Size of the ship in grid spaces"}}},"ResponseOpponentInformationDto":{"type":"object","properties":{"playerName":{"type":"string","description":"Opponent's display name"},"ready":{"type":"bo