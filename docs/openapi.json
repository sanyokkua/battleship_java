{"openapi":"3.1.0","info":{"title":"Battleship API","description":"REST API for the Battleship game backend (session, preparation, gameplay)","version":"2.0.0"},"servers":[{"url":"http://localhost:8080","description":"Generated server url"}],"tags":[{"name":"Game Session","description":"Game session lifecycle: creating sessions and players, and retrieving session stage and change time"},{"name":"Preparation","description":"Ship placement/removal, opponent info, and readiness during the PREPARATION stage"},{"name":"Gameplay","description":"In-game state retrieval and shot resolution during the IN_GAME stage"}],"paths":{"/api/v2/game/sessions/{sessionId}/players/{playerId}/ships/{shipId}":{"put":{"tags":["Preparation"],"summary":"Place a ship on the board","description":"Registers a ship's coordinates and orientation for the given player during PREPARATION. Fails if the stage isn't PREPARATION, the ship id/direction/coordinate is invalid, the ship is already placed, or the placement overlaps another ship or leaves the board.","operationId":"addShipToField","parameters":[{"name":"sessionId","in":"path","description":"Session identifier","required":true,"schema":{"type":"string"},"example":"abc123"},{"name":"playerId","in":"path","description":"Player identifier","required":true,"schema":{"type":"string"},"example":"p1"},{"name":"shipId","in":"path","description":"Ship type identifier from the edition's ship catalog","required":true,"schema":{"type":"string"},"example":"patrol_boat_1"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ParamShipDto"}}},"required":true},"responses":{"200":{"description":"Ship placed","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ResponseShipAddedDto"},"examples":{"success":{"description":"success","value":{"shipId":"patrol_boat_1"}}}}}},"400":{"description":"Invalid ship id/direction/coordinate, wrong stage, or ship already placed / overlaps","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"playerIdInvalid":{"description":"playerIdInvalid","value":{"status":400,"errorMessage":"...","errorCode":"PLAYER_ID_INVALID"}},"shipIdInvalid":{"description":"shipIdInvalid","value":{"status":400,"errorMessage":"...","errorCode":"SHIP_ID_INVALID"}},"shipDirectionInvalid":{"description":"shipDirectionInvalid","value":{"status":400,"errorMessage":"...","errorCode":"SHIP_DIRECTION_INVALID"}},"coordinateInvalid":{"description":"coordinateInvalid","value":{"status":400,"errorMessage":"...","errorCode":"COORDINATE_INVALID"}},"sessionNotFound":{"description":"sessionNotFound","value":{"status":400,"errorMessage":"...","errorCode":"SESSION_NOT_FOUND"}},"stageInvalid":{"description":"stageInvalid","value":{"status":400,"errorMessage":"...","errorCode":"STAGE_INVALID"}},"shipAlreadyPlaced":{"description":"shipAlreadyPlaced","value":{"status":400,"errorMessage":"...","errorCode":"SHIP_ALREADY_PLACED"}}}}}},"500":{"description":"Unexpected internal error (e.g. intersection resolution failure)","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"internal":{"description":"internal","value":{"status":500,"errorMessage":"...","errorCode":"INTERNAL"}}}}}}}}},"/api/v2/game/sessions":{"post":{"tags":["Game Session"],"summary":"Create a game session","description":"Creates a new session for the given game edition. Fails if the edition name is blank or not a recognized GameEdition.","operationId":"createGameSession","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ParamGameEditionDto"}}},"required":true},"responses":{"201":{"description":"Session created","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ResponseCreatedSessionIdDto"},"examples":{"success":{"description":"success","value":{"sessionId":"abc123"}}}}}},"400":{"description":"Invalid or unrecognized game edition","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"editionInvalid":{"description":"editionInvalid","value":{"status":400,"errorMessage":"...","errorCode":"EDITION_INVALID"}}}}}}}}},"/api/v2/game/sessions/{sessionId}/players":{"post":{"tags":["Game Session"],"summary":"Create a player in a session","description":"Registers a new player under the given session. Fails if the player name is blank, the session id is unknown, the session already has 2 players, or the session is not in a stage that allows joining.","operationId":"createPlayerInSession","parameters":[{"name":"sessionId","in":"path","description":"Session identifier returned by session creation","required":true,"schema":{"type":"string"},"example":"abc123"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ParamPlayerNameDto"}}},"required":true},"responses":{"201":{"description":"Player created","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ResponseCreatedPlayerDto"},"examples":{"success":{"description":"success","value":{"playerId":"p1","playerName":"Alice"}}}}}},"400":{"description":"Invalid player name, unknown session, session full, or wrong stage","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"playerNameInvalid":{"description":"playerNameInvalid","value":{"status":400,"errorMessage":"...","errorCode":"PLAYER_NAME_INVALID"}},"sessionNotFound":{"description":"sessionNotFound","value":{"status":400,"errorMessage":"...","errorCode":"SESSION_NOT_FOUND"}},"sessionFull":{"description":"sessionFull","value":{"status":400,"errorMessage":"...","errorCode":"SESSION_FULL"}},"stageInvalid":{"description":"stageInvalid","value":{"status":400,"errorMessage":"...","errorCode":"STAGE_INVALID"}}}}}},"500":{"description":"Unexpected internal error","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"internal":{"description":"internal","value":{"status":500,"errorMessage":"...","errorCode":"INTERNAL"}}}}}}}}},"/api/v2/game/sessions/{sessionId}/players/{playerId}/start":{"post"