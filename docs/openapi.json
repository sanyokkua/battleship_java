 isn't this player's turn, the cell was already shot, or the session isn't in the IN_GAME stage.","operationId":"makeShotByField","parameters":[{"name":"sessionId","in":"path","description":"Session identifier","required":true,"schema":{"type":"string"},"example":"abc123"},{"name":"playerId","in":"path","description":"Shooting player's identifier","required":true,"schema":{"type":"string"},"example":"p1"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ParamCoordinateDto"}}},"required":true},"responses":{"200":{"description":"Shot resolved","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ResponseShotResultDto"},"examples":{"success":{"description":"success","value":{"shotResult":"HIT"}}}}}},"400":{"description":"Invalid input, unknown session, not this player's turn, cell already shot, or wrong stage","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"playerIdInvalid":{"description":"playerIdInvalid","value":{"status":400,"errorMessage":"...","errorCode":"PLAYER_ID_INVALID"}},"coordinateInvalid":{"description":"coordinateInvalid","value":{"status":400,"errorMessage":"...","errorCode":"COORDINATE_INVALID"}},"sessionNotFound":{"description":"sessionNotFound","value":{"status":400,"errorMessage":"...","errorCode":"SESSION_NOT_FOUND"}},"playerNotActive":{"description":"playerNotActive","value":{"status":400,"errorMessage":"...","errorCode":"PLAYER_NOT_ACTIVE"}},"cellAlreadyShot":{"description":"cellAlreadyShot","value":{"status":400,"errorMessage":"...","errorCode":"CELL_ALREADY_SHOT"}},"stageInvalid":{"description":"stageInvalid","value":{"status":400,"errorMessage":"...","errorCode":"STAGE_INVALID"}}}}}},"500":{"description":"Unexpected internal error","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"internal":{"description":"internal","value":{"status":500,"errorMessage":"...","errorCode":"INTERNAL"}}}}}}}}},"/api/v2/game/sessions/{sessionId}/state":{"get":{"tags":["Game Session"],"summary":"Get current game stage","description":"Returns the session's current GameStage. Fails if the session id is unknown.","operationId":"getCurrentGameStage","parameters":[{"name":"sessionId","in":"path","description":"Session identifier","required":true,"schema":{"type":"string"},"example":"abc123"}],"responses":{"200":{"description":"Current stage","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ResponseCurrentGameStageDto"},"examples":{"success":{"description":"success","value":{"gameStage":"PREPARATION"}}}}}},"400":{"description":"Unknown session id","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"sessionNotFound":{"description":"sessionNotFound","value":{"status":400,"errorMessage":"...","errorCode":"SESSION_NOT_FOUND"}}}}}}}}},"/api/v2/game/sessions/{sessionId}/players/{playerId}/state":{"get":{"tags":["Gameplay"],"summary":"Get gameplay state for a player","description":"Returns the requesting player's and opponent's boards, alive-cell/ship counts, and win state. Fails if the player id is malformed, the session is unknown, or the player/opponent can't be resolved in this session.","operationId":"getGameStateForPlayer","parameters":[{"name":"sessionId","in":"path","description":"Session identifier","required":true,"schema":{"type":"string"},"example":"abc123"},{"name":"playerId","in":"path","description":"Requesting player's identifier","required":true,"schema":{"type":"string"},"example":"p1"}],"responses":{"200":{"description":"Gameplay state for the requesting player","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ResponseGameplayStateDto"}}}},"400":{"description":"Invalid player id, unknown session, or player/opponent not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExceptionDto"},"examples":{"playerIdInvalid":{"description":"playerIdInvalid","value":{"status":400,"errorMessage":"...","errorCode":"PLAYER_ID_INVALID"}},"sessionNotFound":{"descripti